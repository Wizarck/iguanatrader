{
  "mcpServers": {
    "atlassian": {
      "env": {
        "ATLASSIAN_API_TOKEN": "${ATLASSIAN_API_TOKEN}",
        "ATLASSIAN_URL": "${ATLASSIAN_URL}"
      }
    },
    "atlassian-geeplo": {
      "httpUrl": "https://eligia-atlassian.palafitofood.com/mcp"
    },
    "camoufox": {
      "_caveman_original": {
        "args": [],
        "command": "npx -y camoufox-mcp-server"
      },
      "_caveman_wrapped": true,
      "args": [
        "-y",
        "caveman-shrink",
        "--",
        "npx -y camoufox-mcp-server"
      ],
      "command": "npx"
    },
    "context7": {
      "httpUrl": "https://mcp.context7.com/mcp"
    },
    "crm": {
      "env": {
        "TWENTY_API_KEY": "${TWENTY_API_KEY}",
        "TWENTY_API_URL": "${TWENTY_API_URL}"
      }
    },
    "google-workspace": {
      "env": {
        "GOOGLE_CLIENT_ID": "${GOOGLE_CLIENT_ID}",
        "GOOGLE_OAUTH_TOKEN": "${GOOGLE_OAUTH_TOKEN}"
      }
    },
    "google-workspace-arturo": {
      "httpUrl": "https://eligia-gws-arturo.palafitofood.com"
    },
    "google-workspace-palafito": {
      "httpUrl": "https://eligia-gws-palafito.palafitofood.com"
    },
    "guardrails-mcp": {
      "env": {
        "GUARDRAILS_API_KEY": "${GUARDRAILS_API_KEY}",
        "GUARDRAILS_URL": "${GUARDRAILS_URL}"
      }
    },
    "hindsight": {
      "env": {
        "CF_ACCESS_CLIENT_ID": "${CF_ACCESS_CLIENT_ID}",
        "CF_ACCESS_CLIENT_SECRET": "${CF_ACCESS_CLIENT_SECRET}",
        "HINDSIGHT_BANK_ID": "${HINDSIGHT_BANK_ID}",
        "HINDSIGHT_URL": "${HINDSIGHT_URL}"
      },
      "httpUrl": "https://eligia-hindsight.palafitofood.com"
    },
    "litellm": {
      "env": {
        "LITELLM_MASTER_KEY": "${LITELLM_MASTER_KEY}",
        "LITELLM_URL": "${LITELLM_URL}"
      }
    },
    "miro": {
      "httpUrl": "https://mcp.miro.com/"
    },
    "ms365-onedrive": {
      "_caveman_original": {
        "args": [],
        "command": "npx -y @softeria/ms-365-mcp-server"
      },
      "_caveman_wrapped": true,
      "args": [
        "-y",
        "caveman-shrink",
        "--",
        "npx -y @softeria/ms-365-mcp-server"
      ],
      "command": "npx"
    },
    "notebooklm": {},
    "paperclip": {},
    "rag": {},
    "skills-manager": {},
    "skills-registry": {
      "env": {
        "SKILLS_REGISTRY_URL": "${SKILLS_REGISTRY_URL}"
      }
    },
    "trello": {
      "_caveman_original": {
        "args": [],
        "command": "npx -y trello-mcp"
      },
      "_caveman_wrapped": true,
      "args": [
        "-y",
        "caveman-shrink",
        "--",
        "npx -y trello-mcp"
      ],
      "command": "npx",
      "env": {
        "TRELLO_API_KEY": "${TRELLO_API_KEY}",
        "TRELLO_TOKEN": "${TRELLO_TOKEN}"
      }
    },
    "tspoonlab": {},
    "twenty-crm": {},
    "whatsapp": {},
    "woocommerce": {}
  }
}
